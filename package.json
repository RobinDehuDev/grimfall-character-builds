{
  "name": "gimfall-character-builds",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "import:abilities": "IMPORT_UNKNOWN=0 node scripts/import-grimfall-abilities.mjs && node scripts/merge-wowhead-abilities.mjs && node scripts/flag-probably-talents.mjs && node scripts/fix-ability-wotlk-class.mjs",
    "import:abilities:full": "IMPORT_UNKNOWN=1 node scripts/import-grimfall-abilities.mjs && node scripts/merge-wowhead-abilities.mjs && node scripts/flag-probably-talents.mjs && node scripts/fix-ability-wotlk-class.mjs",
    "generate:talents": "node scripts/generate-wotlk-talents.mjs && cp data/wotlk-talents.json convex/seed/data/wotlk-talents.json && cp data/wotlk-abilities.json convex/seed/data/wotlk-abilities.json",
    "split:grid-abilities": "node scripts/split-talent-grid-abilities.mjs",
    "generate:abilities": "node scripts/generate-wotlk-abilities.mjs && cp data/wotlk-abilities.json convex/seed/data/wotlk-abilities.json",
    "generate:data": "pnpm generate:talents && pnpm generate:abilities",
    "generate:talent-effects": "vitest run scripts/talent-effect-parser.test.ts && node scripts/generate-talent-effect-taxonomy.mjs",
    "backfill:talent-effects": "npx convex run seed/backfillTalentEffects:run",
    "seed": "npx convex run seed/reseedAll:run",
    "lint": "eslint .",
    "test": "vitest run",
    "preview": "vite preview"
  },
  "dependencies": {
    "@clerk/react": "^6.10.2",
    "@fontsource/open-sans": "^5.2.7",
    "@radix-ui/react-checkbox": "^1.3.5",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.41.0",
    "i18next": "^26.3.1",
    "lucide-react": "^1.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.18.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.1",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.9"
  }
}
